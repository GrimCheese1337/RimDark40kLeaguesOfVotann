<Defs>

  <!-- Ancestor Core -->
  <ResearchProjectDef ParentName="BEWH_VotannResearchBase">
    <defName>BEWH_AncestorCore</defName>
    <label>Fane</label>
    <description>[Placeholder]Unlocks the ability to construct your own Fane.</description>
    <techLevel>Spacer</techLevel>
    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
    <requiredResearchFacilities>
      <li>MultiAnalyzer</li>
    </requiredResearchFacilities>
    <prerequisites>
      <li>MicroelectronicsBasics</li>
    </prerequisites>
    <baseCost>3000</baseCost>
    <researchViewX>1</researchViewX>
    <researchViewY>4</researchViewY>
    <discoveredLetterTitle>About: Fane</discoveredLetterTitle>
    <discoveredLetterText>[Placeholder]You now have the technology to create Ancestor Cores. Each pawn with the "Cloneskein" gene can be uploaded into the Ancestor Core, giving Global Learning factor to all other pawns with the "Cloneskein" gene. Additionally crucibles can be linked to the core, allowing for "Kin" to be gestated.</discoveredLetterText>
  </ResearchProjectDef>

